---
/**
 * AdsLayout.astro — Layout simplificado para landing pages de Google Ads
 *
 * Diferenças vs BaseLayout:
 *   - Nav sem links de âncora — apenas logo + único CTA (reduz distrações)
 *   - Footer mínimo — sem colunas de links que desviam da conversão
 *   - Mantém: scroll reveal, sticky mobile CTA, WhatsApp float
 */
import SEO from '../components/layout/SEO.astro';
import '../../design-system/tokens.css';
import '../../design-system/typography.css';
import '../styles/global.css';
import '../styles/king-tokens.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title,
  description,
  image,
  canonical,
  noindex,
  ctaText = 'Book Now — €14.99',
  ctaHref = '#book',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="https://barcelonapubcrawlbyking.com/wp-content/uploads/2024/02/Logo_Website-no-bg.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Poppins:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet" />
  <SEO
    title={title}
    description={description}
    image={image}
    canonical={canonical}
    noindex={noindex}
  />
  <!-- Google Ads conversion tracking snippet goes here -->
</head>
<body>

  <!-- ── Ads Nav: logo + CTA only (no exit links) ──────────── -->
  <header class="ads-nav" id="adsNav">
    <div class="ads-nav__inner">
      <a href="#hero" class="ads-nav__logo">
        <img
          src="https://barcelonapubcrawlbyking.com/wp-content/uploads/2024/02/Logo_Website-no-bg.png"
          alt="Barcelona Pub Crawl by KING"
          width="140"
          height="36"
          style="height:36px;width:auto;filter:brightness(0) invert(1);"
          loading="eager"
        />
      </a>
      <div class="ads-nav__right">
        <a
          href="http://wa.me/34665605282"
          class="ads-nav__wa"
          target="_blank"
          rel="noopener"
          aria-label="WhatsApp"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
        <a href={ctaHref} class="btn-gold ads-nav__cta">{ctaText}</a>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Minimal footer -->
  <footer class="ads-footer">
    <div class="ads-footer__inner">
      <span>© 2026 Barcelona Pub Crawl by KING. All rights reserved.</span>
      <nav class="ads-footer__links" aria-label="Footer links">
        <a href="https://barcelonapubcrawlbyking.com/privacy-policy/" target="_blank" rel="noopener">Privacy</a>
        <a href="https://barcelonapubcrawlbyking.com/" target="_blank" rel="noopener">Main Site</a>
        <a href="http://wa.me/34665605282" target="_blank" rel="noopener">Contact</a>
      </nav>
    </div>
  </footer>

  <!-- WhatsApp float button -->
  <a href="http://wa.me/34665605282" class="wa-float" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor" width="26" height="26" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="wa-float__label">Any questions?</span>
  </a>

  <!-- Sticky mobile CTA — appears after hero leaves viewport -->
  <div class="sticky-mob" id="stickyMob">
    <a href="#book" class="sticky-mob__btn">Join Tonight's Tour — From €14.99</a>
  </div>

  <!-- JS: scroll behavior + reveal fallback -->
  <script>
    // Nav: transparent → frosted on scroll
    const nav = document.getElementById('adsNav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('ads-nav--scrolled', window.scrollY > 50);
    }, { passive: true });

    // Sticky mobile CTA: show after hero exits viewport
    const stickyMob = document.getElementById('stickyMob');
    const heroEl = document.getElementById('hero');
    if (stickyMob && heroEl) {
      const io = new IntersectionObserver(
        ([entry]) => stickyMob.classList.toggle('visible', !entry.isIntersecting),
        { threshold: 0 }
      );
      io.observe(heroEl);
    }

    // Scroll reveal fallback for browsers without animation-timeline: view()
    if (!CSS.supports('animation-timeline', 'view()')) {
      const els = document.querySelectorAll('[data-reveal]');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = parseInt(entry.target.getAttribute('data-delay') ?? '0') * 90;
            setTimeout(() => entry.target.classList.add('visible'), delay);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });
      els.forEach(el => observer.observe(el));
    }
  </script>

  <!-- TicketingHub booking widget -->
  <script src='https://widget.ticketinghub.com/embedding/latest.js'></script>

</body>
</html>

<style>
  /* ── Ads Nav ──────────────────────────────────────────────── */
  .ads-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.875rem 1.5rem;
    transition: background var(--transition-base), border-color var(--transition-base);
    border-bottom: 1px solid transparent;
  }

  .ads-nav--scrolled {
    background: rgba(16,15,15,0.96);
    border-color: rgba(230,198,0,0.12);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .ads-nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .ads-nav__logo { display: flex; align-items: center; text-decoration: none; }

  .ads-nav__right {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .ads-nav__wa {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: rgba(37,211,102,0.15);
    color: #25d366;
    text-decoration: none;
    transition: background var(--transition-base);
    flex-shrink: 0;
  }

  .ads-nav__wa:hover { background: rgba(37,211,102,0.28); }

  .ads-nav__cta {
    padding: 0.5rem 1.125rem;
    font-size: 0.8125rem;
    font-weight: 700;
    white-space: nowrap;
  }

  /* ── Ads Footer ───────────────────────────────────────────── */
  .ads-footer {
    background: #0a0a0a;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 1.5rem 1.5rem;
  }

  .ads-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-faint);
  }

  .ads-footer__links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .ads-footer__links a {
    color: var(--color-text-faint);
    text-decoration: none;
    transition: color var(--transition-base);
  }
  .ads-footer__links a:hover { color: var(--color-text-muted); }

  /* ── WhatsApp Float ──────────────────────────────────────── */
  .wa-float {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 90;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #25d366;
    color: #fff;
    border-radius: 2rem;
    padding: 0.625rem 1rem 0.625rem 0.875rem;
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 600;
    box-shadow: 0 4px 20px rgba(37,211,102,0.4);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .wa-float:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(37,211,102,0.5);
  }

  @media (max-width: 480px) {
    .wa-float__label { display: none; }
    .wa-float { padding: 0.75rem; border-radius: 50%; bottom: 5.5rem; right: 1.25rem; }
  }

  /* ── Sticky Mobile CTA ───────────────────────────────────── */
  .sticky-mob {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 80;
    padding: 0.75rem 1rem;
    background: rgba(16,15,15,0.98);
    border-top: 1px solid rgba(230,198,0,0.2);
    transform: translateY(100%);
    transition: transform 0.3s var(--_ease-out);
  }

  .sticky-mob.visible { transform: translateY(0); }

  .sticky-mob__btn {
    display: block;
    width: 100%;
    text-align: center;
    background: var(--color-brand);
    color: #100f0f;
    font-weight: 800;
    font-size: 0.9375rem;
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius-card);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: background var(--transition-base);
  }
  .sticky-mob__btn:hover { background: var(--color-brand-bright); }

  @media (max-width: 768px) {
    .sticky-mob { display: block; }
    .wa-float { bottom: 5.5rem; }
  }
</style>
