---
/**
 * Footer.astro — Footer configurável
 * Props:
 *   logo       - Nome do logo
 *   columns    - Array de colunas com links
 *   copyright  - Texto de copyright
 *   socials    - Array de { icon, href } para redes sociais
 */
interface FooterColumn {
  title: string;
  links: { label: string; href: string }[];
}

interface Props {
  logo?: string;
  columns?: FooterColumn[];
  copyright?: string;
  socials?: { label: string; href: string; icon?: string }[];
}

const {
  logo = 'Site',
  columns = [],
  copyright = `© ${new Date().getFullYear()} ${logo}. Todos os direitos reservados.`,
  socials = [],
} = Astro.props;
---

<footer class="border-t border-white/6 bg-[var(--color-bg)]">
  {columns.length > 0 && (
    <div class="max-w-6xl mx-auto px-8 py-16">
      <div class:list={['grid gap-10', `grid-cols-1 md:grid-cols-${Math.min(columns.length + 1, 4)}`]}>
        <!-- Brand column -->
        <div>
          <span class="font-display font-black text-lg text-white">{logo}</span>
          {socials.length > 0 && (
            <div class="flex gap-4 mt-6">
              {socials.map(s => (
                <a href={s.href} class="text-[#9a9a9a] hover:text-white transition-colors text-sm" target="_blank" rel="noopener noreferrer">
                  {s.label}
                </a>
              ))}
            </div>
          )}
        </div>
        <!-- Link columns -->
        {columns.map(col => (
          <div>
            <h4 class="text-[11px] font-bold tracking-[3px] uppercase text-[var(--color-primary)] mb-5">{col.title}</h4>
            <ul class="list-none flex flex-col gap-3">
              {col.links.map(link => (
                <li>
                  <a href={link.href} class="text-[#9a9a9a] hover:text-white text-sm no-underline transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Bottom bar -->
  <div class="max-w-6xl mx-auto px-8 py-6 flex flex-wrap items-center justify-between gap-4 border-t border-white/5">
    <span class="font-display font-black text-sm text-white">{logo}</span>
    <span class="text-[13px] text-[#9a9a9a]">{copyright}</span>
  </div>
</footer>
