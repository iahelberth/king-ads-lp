---
/**
 * Timeline.astro — Processo/steps verticais com animação de linha
 * A linha vertical cresce via scroll-driven animation (CSS puro).
 *
 * Props:
 *   tag     - Eyebrow text (opcional)
 *   title   - Título da seção
 *   items   - Array de { number?, icon?, title, description, tag? }
 *   variant - 'default' | 'alternate' (default: 'default')
 *             alternate: conteúdo alterna esquerda/direita em desktop
 *   bg      - 'default' | 'surface' (default: 'default')
 */
interface TimelineItem {
  number?: string | number;
  icon?: string;
  title: string;
  description: string;
  tag?: string;
}

interface Props {
  tag?: string;
  title?: string;
  items: TimelineItem[];
  variant?: 'default' | 'alternate';
  bg?: 'default' | 'surface';
}

const {
  tag,
  title,
  items,
  variant = 'default',
  bg = 'default',
} = Astro.props;
---

<section
  class:list={['section timeline', `timeline--bg-${bg}`, `timeline--${variant}`]}
>
  <div class="container">
    {(tag || title) && (
      <div class="section-header timeline__header" data-reveal>
        {tag && <span class="text-eyebrow">{tag}</span>}
        {title && <h2>{title}</h2>}
      </div>
    )}

    <div class="timeline__track">
      <!-- Linha vertical animada via scroll-driven -->
      <div class="timeline__line" aria-hidden="true">
        <div class="timeline__line-fill"></div>
      </div>

      <!-- Items -->
      {items.map((item, i) => (
        <div
          class:list={[
            'timeline__item',
            variant === 'alternate' && i % 2 !== 0 ? 'timeline__item--right' : '',
          ]}
          data-reveal={variant === 'alternate'
            ? (i % 2 === 0 ? 'left' : 'right')
            : 'right'
          }
          data-delay={String(Math.min(i + 1, 5))}
        >
          <!-- Marcador na linha -->
          <div class="timeline__marker" aria-hidden="true">
            {item.icon ? (
              <span class="timeline__marker-icon">{item.icon}</span>
            ) : (
              <span class="timeline__marker-num">
                {item.number ?? String(i + 1).padStart(2, '0')}
              </span>
            )}
          </div>

          <!-- Conteúdo -->
          <div class="timeline__content">
            {item.tag && (
              <span class="text-eyebrow timeline__item-tag">{item.tag}</span>
            )}
            <h3 class="timeline__item-title">{item.title}</h3>
            <p class="timeline__item-desc">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline--bg-default { background-color: var(--color-bg); }
  .timeline--bg-surface { background-color: var(--color-surface); }

  .timeline__header { margin-bottom: var(--space-content); }

  /* ── Track ───────────────────────────────────────────────── */
  .timeline__track {
    position: relative;
    max-width: 720px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Variante alternate: mais larga para acomodar dois lados */
  .timeline--alternate .timeline__track {
    max-width: 900px;
  }

  /* ── Linha vertical ──────────────────────────────────────── */
  .timeline__line {
    position: absolute;
    left: 1.875rem;
    top: 0;
    bottom: 0;
    width: 1px;
    background-color: var(--color-border);
    transform: translateX(-50%);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .timeline--alternate .timeline__line {
      left: 50%;
    }
  }

  /* Linha colorida cresce conforme scroll via scroll-driven */
  .timeline__line-fill {
    width: 100%;
    background: linear-gradient(to bottom, var(--color-brand), var(--color-brand-dim));
  }

  @supports (animation-timeline: view()) {
    .timeline__line-fill {
      animation: timeline-grow linear both;
      animation-timeline: view();
      animation-range: entry 10% exit 90%;
      /* Trick: anima height de 0 a 100% via scale */
      transform-origin: top;
      height: 100%;
      transform: scaleY(0);
    }
    @keyframes timeline-grow {
      from { transform: scaleY(0); }
      to   { transform: scaleY(1); }
    }
  }

  @supports not (animation-timeline: view()) {
    .timeline__line-fill {
      height: 0%;
      transition: height 0.6s ease;
    }
    .timeline__line.is-growing .timeline__line-fill {
      height: 100%;
    }
  }

  /* ── Item ────────────────────────────────────────────────── */
  .timeline__item {
    display: grid;
    grid-template-columns: 3.75rem 1fr;
    gap: 1.5rem;
    align-items: flex-start;
    padding-bottom: clamp(2rem, 4vw, 3.5rem);
    position: relative;
  }

  .timeline__item:last-child { padding-bottom: 0; }

  /* Variante alternate em desktop */
  @media (min-width: 768px) {
    .timeline--alternate .timeline__item {
      grid-template-columns: 1fr 3.75rem 1fr;
      gap: 2rem;
    }
    .timeline--alternate .timeline__item .timeline__marker {
      order: 2;
    }
    .timeline--alternate .timeline__item .timeline__content {
      order: 1;
      text-align: right;
    }
    .timeline--alternate .timeline__item--right .timeline__content {
      order: 3;
      text-align: left;
    }
  }

  /* ── Marcador ────────────────────────────────────────────── */
  .timeline__marker {
    width: 3.75rem;
    height: 3.75rem;
    border-radius: 50%;
    background: var(--color-surface-raised);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    transition:
      border-color var(--transition-base),
      background-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .timeline__item:hover .timeline__marker {
    border-color: var(--color-brand);
    background-color: color-mix(in srgb, var(--color-brand) 12%, var(--color-surface-raised));
    box-shadow: 0 0 24px -4px color-mix(in srgb, var(--color-brand) 30%, transparent);
  }

  .timeline__marker-num {
    font-family: var(--font-display);
    font-size: var(--_text-sm);
    font-weight: 900;
    color: var(--color-text-muted);
    transition: color var(--transition-base);
  }

  .timeline__item:hover .timeline__marker-num { color: var(--color-brand); }

  .timeline__marker-icon {
    font-size: 1.375rem;
    line-height: 1;
  }

  /* ── Conteúdo ────────────────────────────────────────────── */
  .timeline__content {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-top: 0.75rem;
  }

  .timeline__item-tag { display: block; }

  .timeline__item-title {
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    color: var(--color-text);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .timeline__item-desc {
    font-size: var(--_text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: none;
  }
</style>
