          <span class="hero__trust-platforms">TripAdvisor · Google</span>
        </span>
      </div>

      <!-- H1: keyword match "Pub Crawl Barcelona" -->
      <h1 class="hero__title" data-reveal data-delay="1">
        Barcelona's<br>
        <span class="hero__title--gold">#1 Pub Crawl</span>
      </h1>

      <p class="hero__sub" data-reveal data-delay="2">
        3 handpicked bars. VIP club. 70+ guests every Friday from 10+ hostels.<br>
        <strong>The best night of your trip — guaranteed.</strong>
      </p>

      <!-- Primary CTA -->
      <div class="hero__cta-group" data-reveal data-delay="3">
        <a href="#book" class="btn-gold hero__btn-primary">
          Reserve My Spot — From €14.99
        </a>
        <span class="hero__cta-meta">Everyday · Instant confirmation</span>
      </div>

    </div>

    <!-- Info cards overlapping hero bottom -->
    <div class="container hero__cards" data-reveal data-delay="4">
      <div class="hero-card">
        <span class="hero-card__icon">💶</span>
        <div>
          <div class="hero-card__label">Price</div>
          <div class="hero-card__value">From €14.99</div>
          <div class="hero-card__note">Less than 1 cocktail at the club</div>
        </div>
      </div>
      <div class="hero-card">
        <span class="hero-card__icon">🍺</span>
        <div>
          <div class="hero-card__label">Included</div>
          <div class="hero-card__value">3 Bars + VIP Club</div>
          <div class="hero-card__note">Drinks · Free gift · Skip every queue</div>
        </div>
      </div>
      <div class="hero-card">
        <span class="hero-card__icon">📍</span>
        <div>
          <div class="hero-card__label">Meeting Point</div>
          <div class="hero-card__value">Sent after booking</div>
          <div class="hero-card__note">Always central · Easy to reach</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 2. SOCIAL PROOF TICKER ═══════════════════════════════ -->
  <div class="proof-bar" aria-label="Social proof highlights" role="marquee">
    <div class="proof-bar__inner">
      <div class="proof-bar__track" aria-hidden="true">
        <span>⭐⭐⭐⭐⭐ 4.9/5</span><span class="sep">·</span>
        <span>863+ Verified Reviews</span><span class="sep">·</span>
        <span>#1 Pub Crawl Barcelona</span><span class="sep">·</span>
        <span>Everyday</span><span class="sep">·</span>
        <span>70+ Guests/Night</span><span class="sep">·</span>
        <span>10+ Partner Hostels</span><span class="sep">·</span>
        <span>From €14.99</span><span class="sep">·</span>
        <span>3 Bars + VIP Club</span><span class="sep">·</span>
        <span>Rain or Shine</span><span class="sep">·</span>
        <span>10,847+ Happy Partygoers</span><span class="sep">·</span>
        <span>Skip Every Queue</span><span class="sep">·</span>
        <span>50+ Countries</span><span class="sep">·</span>
        <!-- Loop -->
        <span>⭐⭐⭐⭐⭐ 4.9/5</span><span class="sep">·</span>
        <span>863+ Verified Reviews</span><span class="sep">·</span>
        <span>#1 Pub Crawl Barcelona</span><span class="sep">·</span>
        <span>Everyday</span><span class="sep">·</span>
        <span>70+ Guests/Night</span><span class="sep">·</span>
        <span>10+ Partner Hostels</span><span class="sep">·</span>
        <span>From €14.99</span><span class="sep">·</span>
        <span>3 Bars + VIP Club</span><span class="sep">·</span>
        <span>Rain or Shine</span><span class="sep">·</span>
        <span>10,847+ Happy Partygoers</span><span class="sep">·</span>
        <span>Skip Every Queue</span><span class="sep">·</span>
        <span>50+ Countries</span><span class="sep">·</span>
      </div>
    </div>
  </div>

  <!-- ══ 3. TRUST BAR ═══════════════════════════════════════ -->
